# Copy this file to .env and fill in values before running docker compose up

# PostgreSQL credentials
DB_USER=helios
DB_PASSWORD=changeme
DB_NAME=helios

# Port on the host that PostgreSQL is exposed on (default 5432)
DB_PORT=5432

# Port on the host that the API is exposed on (default 8000)
API_PORT=8000

# Anthropic API key — required for live ordinance research (Claude web search)
ANTHROPIC_API_KEY=

# Mapbox token — optional; enables NY-biased address autocomplete on the input
# form. Server-side only (never sent to the browser). Autocomplete degrades to
# a plain text input when unset.
MAPBOX_TOKEN=
